<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS 10 configuration for PermitSales (PHP edition).

  Requirements on the server:
    * IIS 10 with the CGI role service installed
    * PHP 8.1+ installed (e.g. via the Microsoft Web Platform Installer or
      manually) and registered as a FastCGI handler for *.php
    * URL Rewrite Module 2.x  (https://www.iis.net/downloads/microsoft/url-rewrite)

  Point an IIS site (or virtual directory) at this `public/` folder and the
  app will run as-is. All non-asset requests are routed to index.php so the
  in-app router can handle them, exactly like the .htaccess used under Apache
  or `php -S 127.0.0.1:8000 -t public` during development.

  Configuration:
    * Recommended: place a `.env` file in the parent folder (`php/.env`,
      one level above `public/`). The bootstrap searches `php/.env`,
      `php/public/.env`, and the parent of `php/`.
    * Or set env vars natively in IIS via the FastCGI handler — see the
      commented `<environmentVariables>` example at the bottom of this file.
    * Or point at a specific .env via the `PERMITSALES_ENV_FILE` env var.

  Notepad will sometimes save .env with a UTF-8 BOM, which the loader now
  strips automatically. If you still see "Missing required environment
  variable: DATABASE_URL", visit the site with APP_ENV=dev set and the error
  page will print every path the loader tried and the outcome of each.
-->
<configuration>
  <system.webServer>

    <defaultDocument>
      <files>
        <clear />
        <add value="index.php" />
      </files>
    </defaultDocument>

    <rewrite>
      <rules>
        <!-- Block direct access to dotfiles such as .env (defense in depth;
             nothing sensitive should live under public/ to begin with). -->
        <rule name="Block dotfiles" stopProcessing="true">
          <match url="(^|/)\." ignoreCase="false" />
          <action type="CustomResponse" statusCode="404" statusReason="Not Found" statusDescription="Not Found" />
        </rule>

        <!-- Front-controller: send anything that does NOT map to a real file
             or directory through index.php so the PHP router can dispatch it. -->
        <rule name="Front controller" stopProcessing="true">
          <match url="^(.*)$" ignoreCase="false" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.php" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>

    <httpErrors errorMode="DetailedLocalOnly" />

    <!-- Reasonable default upload size (8 MB). Adjust if you need to accept
         larger POST bodies from forms or APIs. -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="8388608" />
        <hiddenSegments>
          <add segment=".env" />
          <add segment=".git" />
          <add segment="src" />
          <add segment="views" />
          <add segment="vendor" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".sql" allowed="false" />
          <add fileExtension=".lock" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <staticContent>
      <!-- Make sure modern asset types are served with the right MIME type. -->
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
    </staticContent>

  </system.webServer>

  <!--
    OPTIONAL: configure environment variables natively in IIS instead of (or
    in addition to) shipping a `.env` file. Variables set here are pushed
    into the PHP FastCGI worker by IIS and take precedence over any value
    loaded from `.env`.

    To use this, uncomment the block below, fill in real values, and make
    sure the `fullPath` matches the FastCGI process you registered when you
    set up PHP on IIS. The path must match exactly (case + slashes).

    <system.webServer>
      <fastCgi>
        <application fullPath="C:\PHP\php-cgi.exe">
          <environmentVariables>
            <environmentVariable name="DATABASE_URL"        value="postgres://user:pass@localhost:5432/permitsales_php" />
            <environmentVariable name="APP_SECRET"          value="replace-with-at-least-32-characters-of-randomness" />
            <environmentVariable name="CARD_ENCRYPTION_KEY" value="replace-with-base64-of-32-random-bytes" />
            <environmentVariable name="LAST_FOUR_PEPPER"    value="replace-with-at-least-16-characters" />
            <environmentVariable name="APP_ENV"             value="prod" />
          </environmentVariables>
        </application>
      </fastCgi>
    </system.webServer>
  -->
</configuration>
